# ESPN League Configuration
LEAGUE_ID=121269
SEASON=2026
# Optional: Only needed if the league is private
ESPN_S2=
SWID=

# AI Configuration (Get an API key from Google AI Studio: https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Email Configuration (e.g. Gmail SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
# If using Gmail, use an App Password, not your real password
SMTP_PASSWORD=your_app_password
SENDER_EMAIL=your_email@gmail.com
# Comma-separated list of recipient emails
RECIPIENT_EMAILS=owner1@example.com,owner2@example.com
